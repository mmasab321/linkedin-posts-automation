// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id    String @id @default(cuid())
  key   String @unique // GETLATE_API_KEY, MOONSHOT_API_KEY, LINKEDIN_ACCOUNT_ID
  value String
}

model MonthlyQuota {
  id        String @id @default(cuid())
  year      Int
  month     Int // 0-11
  usedCount Int @default(0)
  maxCount  Int @default(15)

  @@unique([year, month])
}

model PostDraft {
  id           String      @id @default(cuid())
  status       DraftStatus @default(PENDING_REVIEW)
  content      String // The LinkedIn text
  topic        String
  postType     String // story, insight, project, tip, hot_take, results
  keyPoint     String
  toneModifier String?
  createdAt    DateTime    @default(now())
  schedule     ScheduleSlot?
}

enum DraftStatus {
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  DISCARDED
  FAILED
}

model ScheduleSlot {
  id            String    @id @default(cuid())
  draftId       String    @unique
  draft         PostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  scheduledFor  DateTime
  getlatePostId String?
  getlateStatus String? // pending, published, failed
}
