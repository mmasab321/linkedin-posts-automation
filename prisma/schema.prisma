// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id    String @id @default(cuid())
  key   String @unique // GETLATE_API_KEY, MOONSHOT_API_KEY, LINKEDIN_ACCOUNT_ID
  value String
}

model MonthlyQuota {
  id        String @id @default(cuid())
  year      Int
  month     Int // 0-11
  usedCount Int @default(0)
  maxCount  Int @default(15)

  @@unique([year, month])
}

model PostDraft {
  id                 String      @id @default(cuid())
  status             DraftStatus @default(PENDING_REVIEW)
  content            String // The LinkedIn text
  topic              String
  postType           String // story, insight, project, tip, hot_take, results
  keyPoint           String
  toneModifier       String?
  firstComment       String? // LinkedIn first comment (CTA, link, etc.)
  disableLinkPreview Boolean?    @default(false) // Disable link preview for URLs in content
  mediaUrls          String? // JSON array of public media URLs for images/videos/PDF
  isAutopilot        Boolean     @default(false) // true when created by autopilot
  createdAt          DateTime    @default(now())
  schedule           ScheduleSlot?
}

enum DraftStatus {
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  DISCARDED
  FAILED
}

model ScheduleSlot {
  id            String    @id @default(cuid())
  draftId       String    @unique
  draft         PostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  scheduledFor  DateTime
  getlatePostId String?
  getlateStatus String? // pending, published, failed
}

// --- Autopilot (premium) ---
model AutopilotConfig {
  id              String    @id @default(cuid())
  enabled         Boolean   @default(false)
  scheduleTime    String    @default("09:00") // 24h format HH:mm
  maxAutoPerMonth Int       @default(10)
  lastRunAt       DateTime?
  nextScheduledAt DateTime?
  validationRules Json      @default("{}") // strict/balanced/relaxed, thresholds
  consecutiveFailures Int   @default(0)
  pausedUntil     DateTime? // manual pause or post-within-6h
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ContentSource {
  id          String   @id @default(cuid())
  type        String   // RSS, EVERGREEN, TRENDING
  url         String?
  title       String
  isActive    Boolean  @default(true)
  priority    Int      @default(50)
  lastFetched DateTime?
  createdAt   DateTime @default(now())
  topics      TopicPool[]
}

model TopicPool {
  id            String        @id @default(cuid())
  sourceId      String
  source        ContentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title         String
  status        String        @default("PENDING") // PENDING, USED, DISCARDED
  usedAt        DateTime?
  priorityBoost Int          @default(0)
  createdAt     DateTime     @default(now())

  @@index([status, createdAt])
}

model AutopilotLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  action          String   // GENERATED, VALIDATED, SCHEDULED, FAILED, SKIPPED
  topic           String
  draftId         String?
  error           String?
  validationScore Int?
}
