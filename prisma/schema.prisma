// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  passwordHash        String?   // for credentials; null if OAuth-only
  emailVerified       DateTime?
  onboardingComplete  Boolean   @default(false)
  plan                String    @default("free") // free | pro | agency
  approvalEmail       String?   // per-user approval email; fallback to APPROVAL_EMAIL env
  isAdmin             Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  configs           Config[]
  monthlyQuotas     MonthlyQuota[]
  postDrafts        PostDraft[]
  autopilotConfigs  AutopilotConfig[]
  contentSources    ContentSource[]
  experienceEntries ExperienceEntry[]
  autopilotLogs     AutopilotLog[]
  userPrompt        UserPrompt?
  voiceProfile      VoiceProfile?
}

model UserPrompt {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  systemPrompt String
  updatedAt    DateTime @updatedAt
}

model VoiceProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  headline      String
  niche         String
  audience      String
  tone          String
  avoidPhrases  String   // comma-separated
  updatedAt     DateTime @updatedAt
}

model Config {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String // GETLATE_API_KEY, MOONSHOT_API_KEY, LINKEDIN_ACCOUNT_ID
  value  String

  @@unique([userId, key])
}

model MonthlyQuota {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  month     Int // 0-11
  usedCount Int @default(0)
  maxCount  Int @default(20)

  @@unique([userId, year, month])
}

model PostDraft {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             DraftStatus @default(PENDING_REVIEW)
  content            String // The LinkedIn text
  topic              String
  postType           String // story, insight, project, tip, hot_take, results
  keyPoint           String
  toneModifier       String?
  firstComment       String? // LinkedIn first comment (CTA, link, etc.)
  disableLinkPreview Boolean?    @default(false) // Disable link preview for URLs in content
  mediaUrls          String? // JSON array of public media URLs for images/videos/PDF
  isAutopilot        Boolean     @default(false) // true when created by autopilot
  approvalToken      String? // one-time token for email approve/reject
  approvalStatus     String? // pending | approved | rejected | expired
  approvalSentAt     DateTime?
  scheduledFor       DateTime? // intended publish time when pending email approval
  engagementScore    Float? // reserved for future LinkedIn API
  manualFeedback     String? // approved | rejected | discarded
  createdAt          DateTime    @default(now())
  schedule           ScheduleSlot?
}

enum DraftStatus {
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  DISCARDED
  FAILED
}

model ScheduleSlot {
  id            String    @id @default(cuid())
  draftId       String    @unique
  draft         PostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  scheduledFor  DateTime
  getlatePostId String?
  getlateStatus String? // pending, published, failed
}

// --- Autopilot (premium) ---
model AutopilotConfig {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled             Boolean   @default(false)
  scheduleTime        String    @default("09:00") // 24h format HH:mm
  maxAutoPerMonth     Int       @default(10)
  lastRunAt           DateTime?
  nextScheduledAt     DateTime?
  validationRules     Json      @default("{}") // strict/balanced/relaxed, thresholds
  consecutiveFailures Int       @default(0)
  pausedUntil         DateTime? // manual pause or post-within-6h
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ContentSource {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // RSS, EVERGREEN, TRENDING
  url         String?
  title       String
  isActive    Boolean  @default(true)
  priority    Int      @default(50)
  lastFetched DateTime?
  createdAt   DateTime @default(now())
  topics      TopicPool[]
}

model TopicPool {
  id            String        @id @default(cuid())
  sourceId      String
  source        ContentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title         String
  status        String        @default("PENDING") // PENDING, USED, DISCARDED
  usedAt        DateTime?
  priorityBoost Int          @default(0)
  createdAt     DateTime     @default(now())

  @@index([status, createdAt])
}

model ExperienceEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // short label e.g. "Built SubSlice in a weekend"
  description String   // 1-3 sentences of context
  tags        String   // comma-separated keywords e.g. "react-native,mvp,speed"
  createdAt   DateTime @default(now())
}

model AutopilotLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  action          String   // GENERATED, VALIDATED, SCHEDULED, FAILED, SKIPPED
  topic           String
  draftId         String?
  error           String?
  validationScore Int?
}
